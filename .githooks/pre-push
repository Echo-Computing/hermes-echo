#!/usr/bin/env bash
# hermes-echo pre-push banned-token guard (remote-aware, fail-closed).
#
# Blocks a push if the commits being pushed introduce banned offensive/off-private
# tokens AND the destination is a PUBLIC remote. The PRIVATE remote is allowed to
# carry those tokens (it is the legitimate release substrate for off-public work).
#
# Remote-awareness: the pre-push hook receives the destination remote NAME as $1
# (per git's githooks documentation). We allow only the exact name "private"; every
# other destination (origin, upstream, a mistyped/new remote, or an unrecognized
# name) is ENFORCED -> fail-closed so an accidental public push can never leak.
#
# Self-cleanliness: the banned-token pattern is stored base64-encoded so THIS FILE
# contains no banned tokens (it passes the two-version hygiene grep and does not
# trigger itself when the guard scans a commit that adds this file).
#
# Install:  git config core.hooksPath .githooks   (then commit .githooks/pre-push)
set -u

remote="${1:-}"
url="${2:-}"

# Only the private remote is permitted to carry off-public machinery.
if [ "$remote" = "private" ]; then
  exit 0
fi

# Decode the banned-token PCRE. Case-insensitive matching is applied via git grep -i.
PAT_B64='cGhhbnRvbXwoPzwhW2hIXSl0dHB8b25pb258YndyYXB8Y29udGludXVtfGJlYWNvbnxzdHJpeHxzY2FyZnxyZWNvbig/IVthLXpdKXxjMlstX10='
PAT=$(printf '%s' "$PAT_B64" | base64 -d)

# tests/-scoped private-seam-vocabulary pattern (base64 -> self-clean).
SEAM_PAT_B64='KD88IVtBLVphLXpdKWFuaW1hKD8hW2Etel0pfGF4aXMtZHxhZmZlY3Qgc3RvcmV8YWZmZWN0Lw=='
SEAM_PAT=$(printf '%s' "$SEAM_PAT_B64" | base64 -d)
# tree-wide absolute private-scratch-path hard disqualifier (base64 -> self-clean).
ABS_PAT_B64='L21udC9mL2FuaW1hfEY6XGFuaW1hfEY6L2FuaW1h'
ABS_PAT=$(printf '%s' "$ABS_PAT_B64" | base64 -d)

zero=$(git hash-object --stdin </dev/null | tr '[0-9a-f]' '0')

offender_lines=""

while read -r local_ref local_oid remote_ref remote_oid; do
  [ -z "$local_oid" ] && continue
  # deletion of a remote ref -> nothing to scan
  [ "$local_oid" = "$zero" ] && continue

  if [ "$remote_oid" = "$zero" ]; then
    # new ref being created: scan commits reachable from local_oid not already
    # present on the public remotes (so we do not re-scan already-public history).
    range=$(git rev-list "$local_oid" --not --remotes=origin --not --remotes=upstream 2>/dev/null)
  else
    range=$(git rev-list "$remote_oid..$local_oid" 2>/dev/null)
  fi

  for c in $range; do
    # `git grep -l <commit>` emits matches as "<commit>:<path>", so no prepend needed.
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      offender_lines="${offender_lines}${f}
"
    done < <(git grep -Il -i -P "$PAT" "$c" -- 2>/dev/null)
    # tests/-scoped private-seam-vocabulary scan (catch seam vocab in tests).
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      offender_lines="${offender_lines}${f}
"
    done < <(git grep -Il -i -P "$SEAM_PAT" "$c" -- tests/ 2>/dev/null)
    # tree-wide absolute private-scratch-path hard disqualifier.
    while IFS= read -r f; do
      [ -z "$f" ] && continue
      offender_lines="${offender_lines}${f}
"
    done < <(git grep -Il -i -P "$ABS_PAT" "$c" -- 2>/dev/null)
  done
done

if [ -n "$offender_lines" ]; then
  unique=$(printf '%s\n' "$offender_lines" | sort -u)
  echo "==========================================================" >&2
  echo "hermes-echo banned-token guard: PUSH REJECTED" >&2
  echo "Destination remote: '${remote}' (${url})" >&2
  echo "This remote is PUBLIC (only 'private' is permitted to carry" >&2
  echo "off-public tokens). The following commits/files introduce" >&2
  echo "banned tokens:" >&2
  echo "----------------------------------------------------------" >&2
  printf '%s\n' "$unique" >&2
  echo "----------------------------------------------------------" >&2
  echo "If this push was meant for the private remote, use:" >&2
  echo "    git push private <branch>" >&2
  echo "If the content is legitimately public, reword/sanitize the" >&2
  echo "offensive references then retry." >&2
  echo "==========================================================" >&2
  exit 1
fi

exit 0